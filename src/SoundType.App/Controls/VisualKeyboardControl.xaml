<UserControl x:Class="SoundType.App.Controls.VisualKeyboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="KeyboardSurfaceBrush" Color="#07101C"/>
        <SolidColorBrush x:Key="KeyboardZoneBrush" Color="#111A2A"/>
        <SolidColorBrush x:Key="KeyboardKeyBrush" Color="#172238"/>
        <SolidColorBrush x:Key="KeyboardKeyBorderBrush" Color="#3B4762"/>
        <SolidColorBrush x:Key="KeyboardKeyExcludedBrush" Color="#3A1720"/>
        <SolidColorBrush x:Key="KeyboardKeyExcludedBorderBrush" Color="#F87171"/>
        <SolidColorBrush x:Key="KeyboardKeyExcludedTextBrush" Color="#FCA5A5"/>
        <Style x:Key="KeyboardKeyButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E8EAED"/>
            <Setter Property="Background" Value="{StaticResource KeyboardKeyBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource KeyboardKeyBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <DockPanel Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="{StaticResource AccentBrush}" Margin="0,0,6,0"/>
                <TextBlock Text="Active" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,14,0"/>
                <Ellipse Width="9" Height="9" Fill="{StaticResource KeyboardKeyExcludedBorderBrush}" Margin="0,0,6,0"/>
                <TextBlock Text="Muted" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
            </StackPanel>
            <TextBlock Text="Full keyboard" Foreground="{StaticResource MutedTextBrush}"/>
        </DockPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <Border Background="{StaticResource KeyboardSurfaceBrush}"
                    BorderBrush="#3B4762"
                    BorderThickness="2"
                    CornerRadius="18"
                    Padding="16">
                <Grid x:Name="KeyboardGrid"/>
            </Border>
        </ScrollViewer>
    </StackPanel>
</UserControl>
