<Application x:Class="SoundType.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SoundType.App"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#101114"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#191B21"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#22252D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#54D7C6"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9CA7B8"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF7A7A"/>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="Foreground" Value="#F4F7FA"/>
            <Setter Property="BorderBrush" Value="#3A3F4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F7FA"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F4F7FA"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,6,0,10"/>
        </Style>
    </Application.Resources>
</Application>
