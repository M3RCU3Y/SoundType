                            <Grid.RowDefinitions>
                                <RowDefinition Height="60"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="324"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="288"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="146"/>
                            </Grid.RowDefinitions>

                            <Grid Visibility="Collapsed">
                                <ComboBox x:Name="EnterDingSoundComboBox" SelectionChanged="EnterDingSoundComboBox_SelectionChanged"/>
                                <CheckBox x:Name="EnterDingEnabledCheck" Checked="SettingsCheckChanged" Unchecked="SettingsCheckChanged"/>
                            </Grid>

                            <Border Grid.Row="0" Style="{StaticResource SettingsCardStyle}" Padding="18,8">
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Active pack:" Foreground="{StaticResource MutedTextBrush}" FontSize="15" VerticalAlignment="Center"/>
                                        <Border Width="46" Height="46" CornerRadius="8" Background="#182029" BorderBrush="#2C3944" BorderThickness="1" Margin="18,0,14,0">
                                            <Grid ClipToBounds="True">
                                                <TextBlock Text="K" Foreground="{StaticResource AccentHoverBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Image x:Name="SettingsActivePackPreviewImage"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock x:Name="SettingsActivePackNameText" Text="Alpaca Switches" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Border CornerRadius="5" Padding="9,4" Background="#12372E" BorderBrush="#1F6D52" BorderThickness="1" Margin="14,0,12,0">
                                            <TextBlock x:Name="SettingsActivePackTypeText" Text="Mechanical" Foreground="{StaticResource AccentHoverBrush}" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock x:Name="SettingsActivePackSizeText" Text="5.2 MB" Foreground="{StaticResource MutedTextBrush}" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Content="Change Pack" Width="128" Height="40" Click="ShowLibrary_Click"/>
                                </DockPanel>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SettingsCardStyle}" Padding="18">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="38"/>
                                            <RowDefinition Height="52"/>
                                            <RowDefinition Height="52"/>
                                            <RowDefinition Height="52"/>
                                            <RowDefinition Height="1"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE9D2;" Style="{StaticResource SettingsIconTextStyle}" Margin="0,0,16,0"/>
                                            <TextBlock Text="Playback Behavior" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1" Margin="2,0,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE823;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Ignore held-key repeats" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Play sound once when a key is held down" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="IgnoreRepeatsCheck" Style="{StaticResource SettingsSwitchStyle}" Checked="SettingsCheckChanged" Unchecked="SettingsCheckChanged" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="2" Margin="2,0,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE9D2;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Smooth pitch variation" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Add subtle pitch variation for realism" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource SettingsSwitchStyle}" IsChecked="True" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="3" Margin="2,0,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xEC4A;" Style="{StaticResource SettingsIconTextStyle}" Foreground="{StaticResource MutedTextBrush}" FontSize="18"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Low latency mode" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Reduce buffering for best responsiveness" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource SettingsSwitchStyle}" IsChecked="False" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Grid.Row="4" Fill="#2A343D"/>
                                        <Grid Grid.Row="5" Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="210"/><ColumnDefinition Width="*"/><ColumnDefinition Width="82"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Debounce repeated keys" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Filter very fast repeats" Style="{StaticResource SettingsRowDescriptionStyle}" Margin="0,5,0,0"/>
                                            </StackPanel>
                                            <Slider Grid.Column="1" Minimum="0" Maximum="50" Value="20" VerticalAlignment="Center" Margin="8,0,16,0"/>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="20 ms" HorizontalAlignment="Left" FontSize="14"/>
                                                <Border Style="{StaticResource HotkeyChipStyle}" Width="60" Margin="0,7,0,0"><TextBlock Text="20" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SettingsCardStyle}" Padding="18">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="38"/>
                                            <RowDefinition Height="52"/>
                                            <RowDefinition Height="52"/>
                                            <RowDefinition Height="52"/>
                                            <RowDefinition Height="52"/>
                                            <RowDefinition Height="1"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7F4;" Style="{StaticResource SettingsIconTextStyle}" Margin="0,0,16,0"/>
                                            <TextBlock Text="Tray &amp; Startup" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1" Margin="2,0,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8A7;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Minimize to tray" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Keep SoundType running in the system tray" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="MinimizeToTrayCheck" Style="{StaticResource SettingsSwitchStyle}" Checked="SettingsCheckChanged" Unchecked="SettingsCheckChanged" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="2" Margin="2,0,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8BB;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Hide to tray on close" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock x:Name="TrayStatusText" Text="Don't exit when the window is closed" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource SettingsSwitchStyle}" IsChecked="{Binding IsChecked, ElementName=MinimizeToTrayCheck}" IsHitTestVisible="False" Focusable="False" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="3" Margin="2,0,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE945;" Style="{StaticResource SettingsIconTextStyle}" Foreground="{StaticResource MutedTextBrush}" FontSize="18"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Start with Windows" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Launch SoundType when Windows starts" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="StartWithWindowsCheck" Style="{StaticResource SettingsSwitchStyle}" Checked="StartWithWindowsChanged" Unchecked="StartWithWindowsChanged" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="4" Margin="2,0,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE9F5;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Start hidden in tray" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Don't show the window on startup" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="StartHiddenInTrayCheck" Style="{StaticResource SettingsSwitchStyle}" Checked="StartWithWindowsChanged" Unchecked="StartWithWindowsChanged" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Grid.Row="5" Fill="#2A343D"/>
                                        <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Windows startup status:" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentHoverBrush}" FontSize="13" Margin="16,1,7,0"/>
                                            <TextBlock x:Name="StartupStatusText" Text="Enabled" Foreground="{StaticResource AccentHoverBrush}" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SettingsCardStyle}" Padding="18">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="38"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="38"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="38"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="38"/>
                                            <RowDefinition Height="1"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE765;" Style="{StaticResource SettingsIconTextStyle}" Margin="0,0,16,0"/>
                                            <TextBlock Text="Hotkeys" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <Border Grid.Row="1" CornerRadius="6" Background="#111922" BorderBrush="#27323C" BorderThickness="1" Padding="12,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="210"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Toggle Listening" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="48"><TextBlock Text="Ctrl" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                    <TextBlock Text="+" Foreground="{StaticResource MutedTextBrush}" Margin="9,5"/>
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="44"><TextBlock Text="Alt" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                    <TextBlock Text="+" Foreground="{StaticResource MutedTextBrush}" Margin="9,5"/>
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="36"><TextBlock Text="L" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                </StackPanel>
                                                <Button Grid.Column="2" Width="36" Height="34" Padding="0" HorizontalAlignment="Right"><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="15"/></Button>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="3" CornerRadius="6" Background="#111922" BorderBrush="#27323C" BorderThickness="1" Padding="12,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Preview (Normal)" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Style="{StaticResource HotkeyChipStyle}" Width="62" HorizontalAlignment="Right"><TextBlock Text="Space" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                <Button Grid.Column="2" Width="36" Height="34" Padding="0" HorizontalAlignment="Right"><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="15"/></Button>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="5" CornerRadius="6" Background="#111922" BorderBrush="#27323C" BorderThickness="1" Padding="12,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="250"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Next Pack" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="48"><TextBlock Text="Ctrl" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                    <TextBlock Text="+" Foreground="{StaticResource MutedTextBrush}" Margin="9,5"/>
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="44"><TextBlock Text="Alt" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                    <TextBlock Text="+" Foreground="{StaticResource MutedTextBrush}" Margin="9,5"/>
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="64"><TextBlock Text="Right" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                </StackPanel>
                                                <Button Grid.Column="2" Width="36" Height="34" Padding="0" HorizontalAlignment="Right"><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="15"/></Button>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="7" CornerRadius="6" Background="#111922" BorderBrush="#27323C" BorderThickness="1" Padding="12,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="250"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Previous Pack" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="48"><TextBlock Text="Ctrl" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                    <TextBlock Text="+" Foreground="{StaticResource MutedTextBrush}" Margin="9,5"/>
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="44"><TextBlock Text="Alt" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                    <TextBlock Text="+" Foreground="{StaticResource MutedTextBrush}" Margin="9,5"/>
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="58"><TextBlock Text="Left" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                </StackPanel>
                                                <Button Grid.Column="2" Width="36" Height="34" Padding="0" HorizontalAlignment="Right"><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="15"/></Button>
                                            </Grid>
                                        </Border>
                                        <Rectangle Grid.Row="8" Fill="#2A343D" Margin="0,12,0,0"/>
                                        <Button Grid.Row="9" Style="{StaticResource SettingsSmallButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="226">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                                <TextBlock Text="Restore Hotkeys to Defaults"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SettingsCardStyle}" Padding="18">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="36"/>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="1"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEA18;" Style="{StaticResource SettingsIconTextStyle}" Margin="0,0,16,0"/>
                                            <TextBlock Text="Privacy" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE72E;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Local mode active" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="All processing happens on this PC" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE72E;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="No words recorded" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Only key events are used to trigger sounds" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Grid.Row="3">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE72E;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="No key history stored" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Your keystrokes are never logged or saved" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Grid.Row="4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE72E;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Audio files stay on this PC" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Packs you add are never uploaded" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Rectangle Grid.Row="5" Fill="#2A343D"/>
                                        <Grid Grid.Row="6" Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="116"/><ColumnDefinition Width="*"/><ColumnDefinition Width="104"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Local processing" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                            <Rectangle Grid.Column="1" Height="4" Fill="{StaticResource AccentHoverBrush}" RadiusX="2" RadiusY="2" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="2" Text="100% Local" HorizontalAlignment="Right" FontSize="13"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Row="6" Style="{StaticResource SettingsCardStyle}" Padding="18,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="0.95*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                            <TextBlock Text="&#xE7C3;" Style="{StaticResource SettingsIconTextStyle}" Margin="0,0,16,0"/>
                                            <TextBlock Text="Storage" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <TextBlock Text="Packs folder location" Foreground="{StaticResource MutedTextBrush}" FontSize="13" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/><ColumnDefinition Width="152"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Height="40" CornerRadius="6" Background="#121922" BorderBrush="#2A3540" BorderThickness="1" Padding="12,0">
                                                <TextBlock x:Name="PacksFolderPathText" Text="C:\Users\brand\Documents\SoundType\Packs" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            </Border>
                                            <Button Grid.Column="1" Width="44" Height="40" Padding="0" Margin="0,0,10,0" Content="..."/>
                                            <Button Grid.Column="2" Width="144" Height="40" Click="OpenPackFolder_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Open Folder"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                    <Rectangle Grid.Column="1" Fill="#2A343D" Margin="18,30,18,0"/>
                                    <Grid Grid.Column="2" Margin="34,34,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Waveform cache" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                            <TextBlock Text="84 MB" FontWeight="SemiBold" Margin="0,3,0,7"/>
                                            <Button Style="{StaticResource SettingsSmallButtonStyle}" HorizontalAlignment="Left" Click="ClearWaveformCache_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Clear Waveform Cache"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Packs installed" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                            <TextBlock x:Name="SettingsPacksInstalledText" Text="22" FontWeight="SemiBold" Margin="0,3,0,7"/>
                                            <Button Style="{StaticResource SettingsSmallButtonStyle}" HorizontalAlignment="Left" Click="ShowLibrary_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Manage Packs"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
