                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="48"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding VolumeText}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                                                <ProgressBar Grid.Column="1" Style="{StaticResource ThinProgressBarStyle}" Minimum="0" Maximum="150" Value="{Binding VolumePercent}" VerticalAlignment="Center"/>
                                                            </Grid>

                                                            <TextBlock Grid.Column="4" Text="{Binding LastSeenText}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                                            <Border x:Name="EnabledPill" Grid.Column="5" Width="48" Height="24" Background="{StaticResource AccentBrush}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                                <Ellipse Width="18" Height="18" Fill="#F8FAFC" HorizontalAlignment="Right" Margin="0,0,3,0"/>
                                                            </Border>
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding ModeLabel}" Value="Disabled">
                                                                <Setter TargetName="ModeText" Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                <Setter TargetName="EnabledPill" Property="Background" Value="#303840"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>

                                        <DockPanel Grid.Row="2" Margin="20,12,20,18">
                                            <TextBlock x:Name="AppRuleSelectionText" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                            <TextBox DockPanel.Dock="Right" Width="208" Height="36" Text="Search rules..." Foreground="{StaticResource SubtleTextBrush}"/>
                                        </DockPanel>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,18">
                                                <TextBlock Text="Rule editor" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock x:Name="RuleEditorProcessText" DockPanel.Dock="Right" Text="New rule" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>

                                            <TextBlock Text="Process name" Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBox x:Name="ProcessRuleTextBox" Margin="0,6,0,14"/>

                                            <TextBlock Text="Mode" Foreground="{StaticResource MutedTextBrush}"/>
                                            <ComboBox x:Name="RuleModeComboBox" Margin="0,6,0,14"/>

                                            <TextBlock Text="Pack override" Foreground="{StaticResource MutedTextBrush}"/>
                                            <ComboBox x:Name="RulePackComboBox" Margin="0,6,0,18"/>

                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock Text="Volume override" Foreground="{StaticResource MutedTextBrush}"/>
                                                <TextBlock x:Name="RuleVolumeText" DockPanel.Dock="Right" Foreground="{StaticResource AccentHoverBrush}" FontWeight="Bold"/>
                                            </DockPanel>
                                            <Slider x:Name="RuleVolumeSlider" Minimum="0" Maximum="1.5" Value="1" TickFrequency="0.05" ValueChanged="RuleVolumeSlider_ValueChanged"/>

                                            <DockPanel Margin="0,18,0,0">
                                                <TextBlock Text="Enable rule" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="RuleEnabledCheckBox"
                                                          DockPanel.Dock="Right"
                                                          Style="{StaticResource KeyboardSwitchStyle}"
                                                          Checked="RuleEnabledCheckBox_Changed"
                                                          Unchecked="RuleEnabledCheckBox_Changed"/>
                                            </DockPanel>

                                            <Grid Margin="0,24,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Content="Test Rule"/>
                                                <Button Grid.Column="2" Content="Save Rule" Foreground="{StaticResource AccentHoverBrush}" BorderBrush="{StaticResource AccentBrush}" Click="AddAppRule_Click"/>
                                                <Button Grid.Column="4" Content="Delete" Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}" Click="RemoveAppRule_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SectionCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Listening to foreground app" FontSize="18" FontWeight="Bold" Margin="0,0,0,18"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="1"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Last detected" Foreground="{StaticResource MutedTextBrush}"/>
                                                    <TextBlock x:Name="LastDetectedAppText" Text="Unknown" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                                    <Button Content="Detect Current App" HorizontalAlignment="Left" Margin="0,18,0,0" Click="DetectCurrentApp_Click"/>
                                                </StackPanel>
                                                <Rectangle Grid.Column="1" Fill="#2C353D" Margin="10,0"/>
                                                <StackPanel Grid.Column="2" Margin="18,0,0,0">
                                                    <TextBlock Text="Now" FontSize="16" FontWeight="SemiBold"/>
                                                    <TextBlock x:Name="LastDetectedTimeText" Text="Updated just now" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel>
                                        <TextBlock Text="Recent apps" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Button DockPanel.Dock="Right" Content="+  Create Rule" Width="134" Click="FocusNewRule_Click"/>
                                        <ListBox x:Name="RecentAppsList"
                                                 BorderThickness="0"
                                                 Height="42"
                                                 ItemContainerStyle="{StaticResource RecentAppChipItemStyle}"
                                                 SelectionChanged="RecentAppsList_SelectionChanged">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                        </ListBox>
                                    </DockPanel>

                                    <Grid Grid.Row="1" Margin="0,24,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.4*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="0.95*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,12">
                                                <TextBlock Text="App switch activity" FontWeight="SemiBold"/>
                                                <TextBlock Text="last 30 minutes" Foreground="{StaticResource MutedTextBrush}" Margin="8,0,0,0"/>
                                            </DockPanel>
                                            <Grid Height="92">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="1"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="1"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="1"/>
                                                </Grid.RowDefinitions>
                                                <Rectangle Fill="#2C353D"/>
                                                <Rectangle Grid.Row="2" Fill="#2C353D"/>
                                                <Rectangle Grid.Row="4" Fill="#2C353D"/>
                                                <UniformGrid Grid.Row="1" Columns="24" Margin="0,10,0,10">
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="#637BFF" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="{StaticResource DangerBrush}" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="#637BFF" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="#637BFF" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="{StaticResource WarningBrush}" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}" Margin="0,0,0,0"/>
                                                    <Rectangle Width="3" Fill="#AF6BFF" Margin="0,0,0,0"/>
                                                </UniformGrid>
                                                <UniformGrid Grid.Row="3" Columns="24" Margin="0,10,0,10">
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}"/>
                                                    <Rectangle Width="3" Fill="#637BFF"/>
                                                    <Rectangle Width="3" Fill="{StaticResource DangerBrush}"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}"/>
                                                    <Rectangle Width="3" Fill="#637BFF"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}"/>
                                                    <Rectangle Width="3" Fill="#AF6BFF"/>
                                                    <Rectangle Width="3" Fill="{StaticResource WarningBrush}"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}"/>
                                                    <Rectangle Width="3" Fill="#637BFF"/>
                                                    <Rectangle Width="3" Fill="{StaticResource AccentBrush}"/>
                                                </UniformGrid>
                                            </Grid>
                                            <DockPanel Margin="0,8,0,0">
                                                <TextBlock Text="30m" Foreground="{StaticResource MutedTextBrush}"/>
                                                <TextBlock DockPanel.Dock="Right" Text="Now" Foreground="{StaticResource MutedTextBrush}"/>
                                            </DockPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="App" Foreground="{StaticResource MutedTextBrush}"/>
                                                <TextBlock Grid.Column="1" Text="Last seen" Foreground="{StaticResource MutedTextBrush}"/>
                                            </Grid>
                                            <TextBlock x:Name="RecentAppSummaryText" Text="No recent apps detected yet." Foreground="{StaticResource MutedTextBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="SettingsPage" Grid.Row="1" Visibility="Collapsed" Margin="24,20,28,24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,18">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Settings" FontSize="30" FontWeight="SemiBold"/>
                                    <TextBlock Text="Preferences and privacy" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="24,8,0,0"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource SettingsHeaderButtonStyle}" Click="ResetSettingsToDefaults_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="Reset to Defaults"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SettingsPrimaryButtonStyle}" Click="ApplySettings_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;" FontSize="15" Margin="0,0,8,0"/>
                                            <TextBlock Text="Apply"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SettingsHeaderButtonStyle}" Width="54" Padding="0">
                                        <TextBlock Text="..." FontSize="20" Margin="0,-6,0,0"/>
                                    </Button>
                                </StackPanel>
                            </DockPanel>

                            <Rectangle Height="1" Fill="#27313A" Margin="0,0,0,16"/>

                            <Border Style="{StaticResource SettingsCardStyle}" Padding="20,12" Margin="0,0,0,14">
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Active pack:" Foreground="{StaticResource MutedTextBrush}" FontSize="14" VerticalAlignment="Center"/>
                                        <Border Width="46" Height="46" CornerRadius="8" Background="#182029" BorderBrush="#2C3944" BorderThickness="1" Margin="18,0,14,0">
                                            <Grid ClipToBounds="True">
                                                <TextBlock Text="K" Foreground="{StaticResource AccentHoverBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Image x:Name="SettingsActivePackPreviewImage"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock x:Name="SettingsActivePackNameText" Text="Alpaca Switches" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border CornerRadius="5" Padding="9,4" Background="#12372E" BorderBrush="#1F6D52" BorderThickness="1" Margin="14,0,12,0">
                                            <TextBlock Text="Mechanical" Foreground="{StaticResource AccentHoverBrush}" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock x:Name="SettingsActivePackSizeText" Text="5.2 MB" Foreground="{StaticResource MutedTextBrush}" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Content="Change Pack" Style="{StaticResource SettingsSmallButtonStyle}" Click="ShowLibrary_Click"/>
                                </DockPanel>
                            </Border>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SettingsCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE9D2;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <TextBlock Text="Playback Behavior" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <Grid Margin="2,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE823;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Ignore held-key repeats" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Play sound once when a key is held down" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="IgnoreRepeatsCheck" Style="{StaticResource SettingsSwitchStyle}" Checked="SettingsCheckChanged" Unchecked="SettingsCheckChanged" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="2,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE9D2;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Smooth pitch variation" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Add subtle pitch variation for realism" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource SettingsSwitchStyle}" IsChecked="True" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="2,0,0,16">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xEC4A;" Style="{StaticResource SettingsIconTextStyle}" Foreground="{StaticResource MutedTextBrush}" FontSize="18"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Low latency mode" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Reduce buffering for best responsiveness" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource SettingsSwitchStyle}" IsChecked="False" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#2A343D" Margin="0,0,0,14"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/><ColumnDefinition Width="86"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Debounce repeated keys" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Filter very fast repeats" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <Slider Grid.Column="1" Minimum="0" Maximum="50" Value="20" VerticalAlignment="Center" Margin="8,0,14,0"/>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="20 ms" HorizontalAlignment="Center" FontSize="14"/>
                                                <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="56" Margin="0,8,0,0"><TextBlock Text="20" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource SettingsCardStyle}" Margin="8,0,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7F4;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <TextBlock Text="Tray &amp; Startup" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <Grid Margin="2,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8A7;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Minimize to tray" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Keep SoundType running in the system tray" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="MinimizeToTrayCheck" Style="{StaticResource SettingsSwitchStyle}" Checked="SettingsCheckChanged" Unchecked="SettingsCheckChanged" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="2,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8BB;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Hide to tray on close" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock x:Name="TrayStatusText" Text="Don't exit when the window is closed" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource SettingsSwitchStyle}" IsChecked="{Binding IsChecked, ElementName=MinimizeToTrayCheck}" IsHitTestVisible="False" Focusable="False" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="2,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE945;" Style="{StaticResource SettingsIconTextStyle}" Foreground="{StaticResource MutedTextBrush}" FontSize="18"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Start with Windows" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Launch SoundType when Windows starts" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="StartWithWindowsCheck" Style="{StaticResource SettingsSwitchStyle}" Checked="StartWithWindowsChanged" Unchecked="StartWithWindowsChanged" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="2,0,0,16">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE9F5;" Style="{StaticResource SettingsIconTextStyle}" FontSize="18"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Start hidden in tray" Style="{StaticResource SettingsRowTitleStyle}"/>
                                                <TextBlock Text="Don't show the window on startup" Style="{StaticResource SettingsRowDescriptionStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="StartHiddenInTrayCheck" Style="{StaticResource SettingsSwitchStyle}" Checked="StartWithWindowsChanged" Unchecked="StartWithWindowsChanged" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#2A343D" Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Windows startup status:" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentHoverBrush}" FontSize="13" Margin="16,1,6,0"/>
                                            <TextBlock x:Name="StartupStatusText" Text="Enabled" Foreground="{StaticResource AccentHoverBrush}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SettingsCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE765;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <TextBlock Text="Hotkeys" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <Border CornerRadius="6" Background="#111922" BorderBrush="#27323C" BorderThickness="1" Padding="12,0" Height="38" Margin="0,0,0,8">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="Toggle Listening" VerticalAlignment="Center"/>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <Border Style="{StaticResource HotkeyChipStyle}"><TextBlock Text="Ctrl" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                    <TextBlock Text="+" Foreground="{StaticResource MutedTextBrush}" Margin="9,4"/>
                                                    <Border Style="{StaticResource HotkeyChipStyle}"><TextBlock Text="Alt" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                    <TextBlock Text="+" Foreground="{StaticResource MutedTextBrush}" Margin="9,4"/>
                                                    <Border Style="{StaticResource HotkeyChipStyle}" MinWidth="36"><TextBlock Text="L" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                        <Border CornerRadius="6" Background="#111922" BorderBrush="#27323C" BorderThickness="1" Padding="12,0" Height="38" Margin="0,0,0,8">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="Preview (Normal)" VerticalAlignment="Center"/>
                                                <Border DockPanel.Dock="Right" Style="{StaticResource HotkeyChipStyle}" MinWidth="62"><TextBlock Text="Space" Style="{StaticResource HotkeyChipTextStyle}"/></Border>
                                            </DockPanel>
                                        </Border>
                                        <Border CornerRadius="6" Background="#111922" BorderBrush="#27323C" BorderThickness="1" Padding="12,0" Height="38" Margin="0,0,0,8">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="Next Pack" VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Right" Text="Ctrl  +  Alt  +  Right" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                                            </DockPanel>
                                        </Border>
                                        <Border CornerRadius="6" Background="#111922" BorderBrush="#27323C" BorderThickness="1" Padding="12,0" Height="38">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="Previous Pack" VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Right" Text="Ctrl  +  Alt  +  Left" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                                            </DockPanel>
                                        </Border>
                                        <Rectangle Height="1" Fill="#2A343D" Margin="0,12,0,10"/>
                                        <Button Style="{StaticResource SettingsSmallButtonStyle}" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                                <TextBlock Text="Restore Hotkeys to Defaults"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource SettingsCardStyle}" Margin="8,0,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEA18;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <TextBlock Text="Privacy" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <TextBlock Text="Local mode active" Style="{StaticResource SettingsRowTitleStyle}" Margin="34,0,0,0"/>
                                        <TextBlock Text="All processing happens on this PC" Style="{StaticResource SettingsRowDescriptionStyle}" Margin="34,3,0,10"/>
                                        <TextBlock Text="No words recorded" Style="{StaticResource SettingsRowTitleStyle}" Margin="34,0,0,0"/>
                                        <TextBlock Text="Only key events are used to trigger sounds" Style="{StaticResource SettingsRowDescriptionStyle}" Margin="34,3,0,10"/>
                                        <TextBlock Text="No key history stored" Style="{StaticResource SettingsRowTitleStyle}" Margin="34,0,0,0"/>
                                        <TextBlock Text="Your keystrokes are never logged or saved" Style="{StaticResource SettingsRowDescriptionStyle}" Margin="34,3,0,10"/>
                                        <TextBlock Text="Audio files stay on this PC" Style="{StaticResource SettingsRowTitleStyle}" Margin="34,0,0,0"/>
                                        <TextBlock Text="Packs you add are never uploaded" Style="{StaticResource SettingsRowDescriptionStyle}" Margin="34,3,0,14"/>
                                        <Rectangle Height="1" Fill="#2A343D" Margin="0,0,0,14"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/><ColumnDefinition Width="94"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Local processing" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                            <Rectangle Grid.Column="1" Height="4" Fill="{StaticResource AccentHoverBrush}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="100% Local" HorizontalAlignment="Right" FontSize="13"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource SettingsCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="1"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8B7;" Style="{StaticResource SettingsIconTextStyle}"/>
                                            <TextBlock Text="Storage" Style="{StaticResource SettingsSectionTitleStyle}"/>
                                        </StackPanel>
                                        <TextBlock Text="Packs folder location" Foreground="{StaticResource MutedTextBrush}" FontSize="13" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Height="40" CornerRadius="6" Background="#121922" BorderBrush="#2A3540" BorderThickness="1" Padding="12,0" Margin="0,0,10,0">
                                                <TextBlock x:Name="PacksFolderPathText" Text="C:\Users\brand\Documents\SoundType\Packs" VerticalAlignment="Center"/>
                                            </Border>
                                            <Button Grid.Column="1" Style="{StaticResource SettingsSmallButtonStyle}" Click="OpenPackFolder_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Open Folder"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                    <Rectangle Grid.Column="1" Fill="#2A343D" Margin="18,24,18,0"/>
                                    <Grid Grid.Column="2" Margin="34,34,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Waveform cache" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                            <TextBlock Text="84 MB" FontWeight="SemiBold" Margin="0,3,0,7"/>
                                            <Button Style="{StaticResource SettingsSmallButtonStyle}" HorizontalAlignment="Left" Click="ClearWaveformCache_Click" Content="Clear Waveform Cache"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Packs installed" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                            <TextBlock x:Name="SettingsPacksInstalledText" Text="22" FontWeight="SemiBold" Margin="0,3,0,7"/>
                                            <Button Style="{StaticResource SettingsSmallButtonStyle}" HorizontalAlignment="Left" Click="ShowLibrary_Click" Content="Manage Packs"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
