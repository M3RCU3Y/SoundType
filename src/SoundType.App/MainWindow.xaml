                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Rectangle Width="3" Height="18" RadiusX="2" RadiusY="2" Fill="{StaticResource AccentBrush}" Margin="1,0"/>
                                            <Rectangle Width="3" Height="28" RadiusX="2" RadiusY="2" Fill="{StaticResource AccentBrush}" Margin="1,0"/>
                                            <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Fill="{StaticResource AccentBrush}" Margin="1,0"/>
