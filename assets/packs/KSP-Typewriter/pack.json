{
  "id": "ksp-typewriter",
  "name": "Antique Typewriter",
  "author": "Mechvibes Community / KeyboardSounds Pro",
  "version": "1.0.0",
  "description": "KeyboardSounds Pro's antique typewriter profile with crisp key, space, return, and delete one-shots.",
  "license": "MIT. Source: keyboard-sounds/keyboardsounds-pro desktop/bundled-profiles/typewriter.",
  "tags": [
    "typewriter",
    "authentic",
    "keyboardsounds-pro"
  ],
  "groups": {
    "normal": [
      "normal/key.wav",
      "normal/key2.wav"
    ],
    "enter": [
      "enter/enter.wav"
    ],
    "space": [
      "space/space.wav"
    ],
    "backspace": [
      "backspace/delete.wav"
    ],
    "tab": [
      "tab/tab.wav"
    ]
  },
  "keyOverrides": {
    "Enter": "enter",
    "Space": "space",
    "Backspace": "backspace",
    "Delete": "backspace",
    "Tab": "tab"
  },
  "defaults": {
    "volume": 0.62,
    "pitchVariation": 0.012,
    "randomize": true
  }
}
